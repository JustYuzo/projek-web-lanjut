# =====================
# SMARTDRIVE ENV EXAMPLE
# =====================
# Copy file ini menjadi .env di hosting.
# Jangan upload file .env asli ke GitHub.

SECRET_KEY=ganti_dengan_secret_key_yang_panjang_dan_acak
DEBUG=False

ALLOWED_HOSTS=namadomainkamu.com,www.namadomainkamu.com
CSRF_TRUSTED_ORIGINS=https://namadomainkamu.com,https://www.namadomainkamu.com

GEMINI_API_KEY=isi_api_key_gemini_kamu

# Untuk awal hosting, biarkan False dulu sampai SSL/domain benar-benar aktif.
SECURE_SSL_REDIRECT=False

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
