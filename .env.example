# =====================
# SMARTDRIVE ENV EXAMPLE
# =====================
# Cara pakai:
# 1. Copy file ini menjadi .env
# 2. Isi value sesuai data asli kamu
# 3. Jangan upload file .env asli ke GitHub

# =====================
# DJANGO CORE
# =====================
SECRET_KEY=ganti_dengan_secret_key_yang_panjang_dan_acak
DEBUG=False

# Untuk hosting cPanel seperti AnymHost/DomaiNesia:
ALLOWED_HOSTS=namadomainkamu.com,www.namadomainkamu.com
CSRF_TRUSTED_ORIGINS=https://namadomainkamu.com,https://www.namadomainkamu.com

# Untuk testing lokal, boleh pakai ini di file .env lokal:
# ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# =====================
# GEMINI AI
# =====================
GEMINI_API_KEY=isi_api_key_gemini_kamu
GEMINI_VISION_MODEL=gemini-2.5-flash

# =====================
# GOOGLE LOGIN
# =====================
# Isi jika Google Login kamu membaca client id dan secret dari environment.
# Jika masih diatur dari Django Admin SocialApp, bagian ini boleh dibiarkan kosong.
GOOGLE_CLIENT_ID=isi_google_client_id_kamu
GOOGLE_CLIENT_SECRET=isi_google_client_secret_kamu

# =====================
# DATABASE
# =====================
# Untuk awal shared hosting, boleh kosong kalau masih pakai SQLite.
# Jika nanti memakai PostgreSQL atau Railway, isi DATABASE_URL.
DATABASE_URL=

# Contoh PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# =====================
# SECURITY HOSTING
# =====================
# Untuk awal hosting, biarkan False dulu sampai SSL/domain benar-benar aktif.
SECURE_SSL_REDIRECT=False

# Jika domain sudah pakai HTTPS aktif, ini boleh True.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Aktifkan HSTS hanya kalau HTTPS sudah stabil.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
